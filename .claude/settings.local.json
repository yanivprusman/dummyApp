{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "timeout": 5,
            "type": "http",
            "url": "http://localhost:3017/api/feedback/response"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3017/api/feedback/session-end",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
